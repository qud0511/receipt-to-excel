# Receipt-to-Excel v4 — environment variables
# 실행 전 `cp .env.example .env` 후 운영 값으로 채워 사용.
# CLAUDE.md §"보안": .env 는 .gitignore, 본 파일과 키 집합 일치 필수.

# ── 인증 ──────────────────────────────────────────────────────────────────────
# REQUIRE_AUTH=true 면 AZURE_TENANT_ID 와 AZURE_CLIENT_ID 필수.
REQUIRE_AUTH=false
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# ── 데이터베이스 ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///storage/app.db
# FileSystemManager 루트 (per-user FS = {STORAGE_ROOT}/users/{oid}/...). 도커는 named volume.
STORAGE_ROOT=storage

# ── LLM / Ollama ─────────────────────────────────────────────────────────────
# 모델 선정 근거: docs/decisions/ADR-002-ollama-model-selection.md
# 사전 실행: ollama pull qwen2.5vl:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:7b
LLM_ENABLED=false

# ── 관측성 ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS / 업로드 제한 ───────────────────────────────────────────────────────
# CORS_ORIGINS: 빈 값이면 비활성. 콤마 구분 (예: https://app.example.com,https://admin.example.com)
CORS_ORIGINS=
MAX_UPLOAD_SIZE_MB=20
MAX_BATCH_SIZE_MB=200

# ── 도커 배포 (docker-compose.yml 보간 전용, 백엔드 Settings 아님) ───────────────
# UI_PORT: 호스트에 노출할 ui nginx 포트. INSTALL_OCR: true 시 백엔드 이미지에
# easyocr/docling(200MB+) 포함. ollama 컨테이너 사용 시 OLLAMA_BASE_URL=http://ollama:11434.
UI_PORT=8080
INSTALL_OCR=false
