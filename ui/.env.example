# CreditXLSX UI 환경 변수 예시. 실 값은 .env.local 에 (gitignored).

# API base — dev 는 Vite proxy 사용 (vite.config.ts 의 /api → localhost:8000).
VITE_API_BASE=/api

# Azure AD MSAL — REQUIRE_AUTH=true 시 활성. dev 는 false.
VITE_REQUIRE_AUTH=false
VITE_AAD_TENANT_ID=
VITE_AAD_CLIENT_ID=
VITE_AAD_REDIRECT_URI=

# dev MSW worker — true 면 백엔드 없이 mock 데이터로 5 화면 풀 사용.
# 데모/설명/시각 프레젠 용도. 운영 빌드는 항상 false.
VITE_USE_MOCK=false
